{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5199"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns"
    ],
    "resources": [
      "../preview-server.mjs"
    ],
    "targets": "all"
  },
  "productName": "Dispatch",
  "mainBinaryName": "Dispatch",
  "version": "0.5.0",
  "identifier": "com.ejfox.dispatch",
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ejfox/website-dispatch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzRkFEMEM0MTI2RjBEQUIKUldTckRXOFN4TkQ2bzRrVURtaTkwYVQ0QU95U2lORVJSbHpzOEpBSWVraWJEM2RNcWNjV3MreDUK"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Dispatch",
        "width": 700,
        "height": 600,
        "resizable": true,
        "transparent": false,
        "visible": true,
        "useHttpsScheme": true,
        "decorations": true,
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 12,
          "y": 12
        },
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ]
  }
}