{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5199"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns"
    ],
    "targets": "all"
  },
  "productName": "Dispatch",
  "mainBinaryName": "Dispatch",
  "version": "0.2.1",
  "identifier": "com.ejfox.dispatch",
  "plugins": {},
  "app": {
    "windows": [
      {
        "title": "Dispatch",
        "width": 700,
        "height": 600,
        "resizable": true,
        "visible": true,
        "useHttpsScheme": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 12,
          "y": 12
        }
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    }
  }
}