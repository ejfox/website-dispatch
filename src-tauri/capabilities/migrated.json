{
  "identifier": "migrated",
  "description": "permissions that were migrated from v1",
  "local": true,
  "windows": [
    "main",
    "preview"
  ],
  "permissions": [
    "core:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/Library/Mobile Documents/**",
        "$HOME/code/**",
        "$HOME/Library/Application Support/com.ejfox.dispatch/**"
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "cmd": "git",
          "name": "git",
          "sidecar": false
        },
        {
          "args": true,
          "cmd": "yarn",
          "name": "yarn",
          "sidecar": false
        }
      ]
    },
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "notification:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "dialog:default",
    "shell:default",
    "fs:default",
    "clipboard-manager:default",
    "updater:default",
    "process:allow-restart"
  ]
}